# Copy to /etc/pcc2k-agent.env, fill in the real values, chmod 640 root:nogroup.
PCC2K_GATEWAY_URL=wss://gateway.pcc2k.com/agent/v1
PCC2K_AGENT_TOKEN=<enrollment token from OpsHub /agents/new>
PCC2K_AGENT_ID=<Op_Agent.id from enrollment>
PCC2K_CLIENT_NAME=<TH_Client.name>
PCC2K_HOSTNAME=<host as you want it shown in FleetHub>
PCC2K_ROLE=workstation         # or server / laptop / DC / file server / ...
